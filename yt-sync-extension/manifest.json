{
    "manifest_version": 3,
    "name": "YouTube WP Sync - مزامنة يوتيوب ووردبريس",
    "description": "مزامنة فيديوهات يوتيوب مع مقالات وردبريس بشكل تلقائي",
    "version": "1.0.0",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "*://www.youtube.com/*",
        "*://*/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "YouTube WP Sync"
    },
    "content_scripts": [
        {
            "matches": [
                "*://www.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    }
}