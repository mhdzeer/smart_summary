{
  "manifest_version": 3,
  "name": "Smart YT Summarizer Bridge",
  "version": "1.1",
  "description": "Auto-bridge between WordPress and Gemini.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*/*wp-admin/*"
      ],
      "js": [
        "wp_content_script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}